# NerdsOnCall Frontend — copy to .env (git-ignored)

# Spring Boot API (no trailing slash)
# Local:    http://localhost:8080
# Production: https://nerdsoncall-api.shivam.app
NEXT_PUBLIC_API_URL=http://localhost:8080

# Groq — server-side only (app/api/chat/route.ts)
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
